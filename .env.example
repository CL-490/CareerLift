# Docker BuildKit
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# Ollama Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:31b-cloud

# Kokoro TTS (realistic server-side text-to-speech)
# Browse voices at http://localhost:8880/v1/audio/voices once the service is up.
# Popular English voices: af_heart, af_bella, af_sky, am_michael, bf_emma
KOKORO_URL=http://localhost:8880
KOKORO_VOICE=af_heart

# Backend Configuration
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NODE_ENV=development

# Electron Configuration
ELECTRON_START_URL=http://localhost:3000

# Job Finder API Keys
# USAJOBS API - https://developer.usajobs.gov/
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# Adzuna API - https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
